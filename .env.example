# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
APP_ENV=development

# Gmail Configuration
# For sending and scraping emails, we will use Gmail API which needs credentials.json
# Path to your Google Cloud credentials.json file
GCP_CREDENTIALS_PATH=src/core/credentials.json
# Path to OAuth token file (contains refresh_token)
GMAIL_TOKEN_PATH=src/core/token.json
# Optional for cloud/headless deployments:
# Put raw JSON content (single line) from credentials.json and token.json
GMAIL_CREDENTIALS_JSON=
GMAIL_TOKEN_JSON=

# Email Alert Configuration (Where notifications should be sent)
NOTIFICATION_EMAIL=your_email@domain.com
# Notification sender if using standard SMTP or same Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASSWORD=your_app_password_here

# Outreach Settings
# Delay between emails in seconds (to avoid spam logic)
MIN_DELAY_SECONDS=30
MAX_DELAY_SECONDS=90

# Rate limits
MAX_EMAILS_PER_DAY=100
